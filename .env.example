# ─── Pwned-PassChecker — Variables de entorno ────────────────────────────────
# Copia este archivo a .env y ajusta los valores según tu entorno.

# ── HIBP API ─────────────────────────────────────────────────────────────────
HIBP_API_URL=https://api.pwnedpasswords.com/range
HIBP_TIMEOUT=10
HIBP_RETRIES=3
HIBP_USER_AGENT=pwned-checker/2.0 (github.com/tuusuario/Pwned-PassChecker)

# ── Logging ───────────────────────────────────────────────────────────────────
# Niveles: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=WARNING
# LOG_FILE=logs/pwned_checker.log   # descomenta para guardar log en archivo

# ── Generador ─────────────────────────────────────────────────────────────────
DEFAULT_PWD_LENGTH=14

# ── Reportes ──────────────────────────────────────────────────────────────────
REPORTS_DIR=reports
